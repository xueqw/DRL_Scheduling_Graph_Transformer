def main():
    parser = argparse.ArgumentParser(description='DTODRL训练和测试')
    parser.add_argument('--mode', choices=['train', 'test', 'compare'], default='train',
                       help='运行模式')
    parser.add_argument('--config', type=str, help='配置文件路径')
    parser.add_argument('--model-path', type=str, help='模型路径')
    parser.add_argument('--pretrained-gat', type=str,
                       default='gat_autoencoder_final.pth',
                       help='预训练GAT权重路径')
    parser.add_argument('--seed', type=int, default=42, help='随机种子')

    args = parser.parse_args()

    # 设置随机种子
    set_global_seed(args.seed)

    # 加载配置
    config = TrainingConfig()
    if args.config and os.path.exists(args.config):
        with open(args.config, 'r') as f:
            config_dict = json.load(f)
            for k, v in config_dict.items():
                if hasattr(config, k):
                    setattr(config, k, v)

    print("配置参数:")
    print(json.dumps(config.to_dict(), indent=2))

    # 创建输出目录（使用项目相对路径）
    os.makedirs(RESULTS_DIR, exist_ok=True)
    os.makedirs(MODELS_DIR, exist_ok=True)
    os.makedirs(TENSORBOARD_DIR, exist_ok=True)

    if args.mode == 'train':
        print("\n=== 开始训练 ===")

        # 创建环境
        print("创建训练环境...")
        train_env = create_dto_environment(config, seed=args.seed)
        eval_env = create_dto_environment(config, seed=args.seed + 1000)

        # 包装环境
        train_env = DummyVecEnv([lambda: train_env])
        eval_env = DummyVecEnv([lambda: eval_env])

        # 创建模型
        print("创建DTODRL模型...")
        model = MaskablePPO(
            ImprovedGATPolicy,
            train_env,
            learning_rate=config.learning_rate,
            gamma=config.gamma,
            n_steps=config.n_steps,
            batch_size=config.batch_size,
            verbose=1,
            tensorboard_log=TENSORBOARD_DIR,
            policy_kwargs={
                'hidden_dim': config.gat_hidden_dim,
                'gat_heads': config.gat_heads,
                'gat_layers': config.gat_layers
            }
        )

        # 加载预训练GAT权重（如果存在）
        if args.pretrained_gat:
            load_pretrained_gat_weights(model.policy, args.pretrained_gat)

        # 设置回调
        checkpoint_callback = CheckpointCallback(
            save_freq=config.save_freq,
            save_path=MODELS_DIR,
            name_prefix='dtodrl'
        )

        eval_callback = EvalCallback(
            eval_env,
            best_model_save_path=MODELS_DIR,
            log_path=RESULTS_DIR,
            eval_freq=config.eval_freq,
            n_eval_episodes=config.n_eval_episodes,
            deterministic=True,
            render=False
        )

        # 开始训练
        print(f"开始训练，总步数: {config.total_timesteps}")
        start_time = time.time()

        model.learn(
            total_timesteps=config.total_timesteps,
            callback=[checkpoint_callback, eval_callback]
        )

        training_time = time.time() - start_time
        print(f"训练完成，用时: {training_time:.2f}秒")

        # 保存最终模型
        final_model_path = os.path.join(MODELS_DIR, 'dtodrl_final')
        model.save(final_model_path)
        print(f"模型已保存到: {final_model_path}")

    elif args.mode == 'test':
        print("\n=== 测试模型 ===")

        if not args.model_path or not os.path.exists(args.model_path):
            print("请提供有效的模型路径")
            return

        # 创建环境
        env = create_dto_environment(config, seed=args.seed)

        # 加载模型
        model = MaskablePPO.load(args.model_path, env=env)

        # 评估
        results = evaluate_policy(model, env, config.n_eval_episodes)

        print("测试结果:")
        print(json.dumps(results, indent=2))

    elif args.mode == 'compare':
        print("\n=== 对比实验 ===")

        if not args.model_path or not os.path.exists(args.model_path):
            print("请提供有效的模型路径")
            return

        # 创建环境
        env = create_dto_environment(config, seed=args.seed)

        # 加载模型
        model = MaskablePPO.load(args.model_path, env=env)

        # 进行对比
        results = compare_with_baselines(env, model, config.n_eval_episodes)

        # 保存结果
        comparison_results_path = os.path.join(RESULTS_DIR, 'comparison_results.json')
        with open(comparison_results_path, 'w') as f:
            json.dump(results, f, indent=2)

        print(f"对比结果已保存到: {comparison_results_path}")


if __name__ == "__main__":
    main()